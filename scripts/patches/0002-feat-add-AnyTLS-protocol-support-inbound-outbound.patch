--- /dev/null
+++ b/proxy/anytls/client.go
@@ -0,0 +1,168 @@
+package anytls
+
+import (
+	"context"
+	"encoding/binary"
+	"sync"
+	"time"
+
+	M "github.com/sagernet/sing/common/metadata"
+	"github.com/xtls/xray-core/common"
+	"github.com/xtls/xray-core/common/buf"
+	"github.com/xtls/xray-core/common/errors"
+	"github.com/xtls/xray-core/common/net"
+	"github.com/xtls/xray-core/common/protocol"
+	"github.com/xtls/xray-core/common/retry"
+	"github.com/xtls/xray-core/common/session"
+	"github.com/xtls/xray-core/common/signal"
+	"github.com/xtls/xray-core/common/singbridge"
+	"github.com/xtls/xray-core/common/task"
+	core "github.com/xtls/xray-core/core"
+	"github.com/xtls/xray-core/features/policy"
+	"github.com/xtls/xray-core/transport"
+	"github.com/xtls/xray-core/transport/internet"
+	anysession "github.com/xtls/xray-core/proxy/anytls/session"
+)
+
+func init() {
+	common.Must(common.RegisterConfig((*ClientConfig)(nil), func(ctx context.Context, config interface{}) (interface{}, error) {
+		return NewClient(ctx, config.(*ClientConfig))
+	}))
+}
+
+// Client is an outbound handler for the AnyTLS protocol.
+// It maintains a pool of AnyTLS sessions per server destination.
+type Client struct {
+	server        *protocol.ServerSpec
+	policyManager policy.Manager
+
+	poolMu sync.Mutex
+	pool   *anysession.Client // single server, single pool
+}
+
+func NewClient(ctx context.Context, config *ClientConfig) (*Client, error) {
+	if config.Server == nil {
+		return nil, errors.New("no server specified in anytls client config")
+	}
+	server, err := protocol.NewServerSpecFromPB(config.Server)
+	if err != nil {
+		return nil, errors.New("failed to parse server spec").Base(err)
+	}
+	v := core.MustFromContext(ctx)
+	return &Client{
+		server:        server,
+		policyManager: v.GetFeature(policy.ManagerType()).(policy.Manager),
+	}, nil
+}
+
+// Process implements proxy.Outbound.
+func (c *Client) Process(ctx context.Context, link *transport.Link, dialer internet.Dialer) error {
+	outbounds := session.OutboundsFromContext(ctx)
+	ob := outbounds[len(outbounds)-1]
+	if !ob.Target.IsValid() {
+		return errors.New("target not specified")
+	}
+	ob.Name = "anytls"
+	destination := ob.Target
+
+	user := c.server.User
+	account, ok := user.Account.(*MemoryAccount)
+	if !ok {
+		return errors.New("anytls: user account is not a MemoryAccount")
+	}
+
+	sessionPolicy := c.policyManager.ForLevel(user.Level)
+	ctx, cancel := context.WithCancel(ctx)
+	timer := signal.CancelAfterInactivity(ctx, cancel, sessionPolicy.Timeouts.ConnectionIdle)
+
+	pool := c.getPool(ctx, account, dialer)
+
+	stream, err := pool.CreateStream(ctx)
+	if err != nil {
+		return errors.New("anytls: failed to create stream").Base(err)
+	}
+	defer stream.Close()
+
+	errors.LogInfo(ctx, "anytls: tunnelling request to ", destination, " via ", c.server.Destination.NetAddr())
+
+	// Write SOCKS destination address to the stream.
+	if err := M.SocksaddrSerializer.WriteAddrPort(stream, singbridge.ToSocksaddr(destination)); err != nil {
+		return errors.New("anytls: failed to write destination address").Base(err)
+	}
+
+	postRequest := func() error {
+		defer timer.SetTimeout(sessionPolicy.Timeouts.DownlinkOnly)
+		if err := buf.Copy(link.Reader, buf.NewWriter(stream), buf.UpdateActivity(timer)); err != nil {
+			return errors.New("anytls: failed to forward request").Base(err)
+		}
+		return nil
+	}
+
+	getResponse := func() error {
+		defer timer.SetTimeout(sessionPolicy.Timeouts.UplinkOnly)
+		if err := buf.Copy(buf.NewReader(stream), link.Writer, buf.UpdateActivity(timer)); err != nil {
+			return errors.New("anytls: failed to forward response").Base(err)
+		}
+		return nil
+	}
+
+	responseDoneAndCloseWriter := task.OnSuccess(getResponse, task.Close(link.Writer))
+	if err := task.Run(ctx, postRequest, responseDoneAndCloseWriter); err != nil {
+		return errors.New("anytls: connection ends").Base(err)
+	}
+	return nil
+}
+
+// getPool returns (or lazily creates) the session pool for this client.
+// In the current design, one Client == one server == one pool.
+func (c *Client) getPool(ctx context.Context, account *MemoryAccount, dialer internet.Dialer) *anysession.Client {
+	c.poolMu.Lock()
+	defer c.poolMu.Unlock()
+	if c.pool != nil {
+		return c.pool
+	}
+
+	server := c.server
+	dialOut := func(dialCtx context.Context) (net.Conn, error) {
+		var conn net.Conn
+		err := retry.ExponentialBackoff(5, 100).On(func() error {
+			rawConn, err := dialer.Dial(dialCtx, server.Destination)
+			if err != nil {
+				return err
+			}
+			conn = rawConn
+			return nil
+		})
+		if err != nil {
+			return nil, errors.New("anytls: failed to dial server").Base(err)
+		}
+
+		// Send auth header: sha256(password)[32] + padding_len[2] + padding[n]
+		paddingF := anysession.DefaultPaddingFactory.Load()
+		var paddingLen int
+		if pads := paddingF.GenerateRecordPayloadSizes(0); len(pads) > 0 {
+			paddingLen = pads[0]
+		}
+
+		authBuf := make([]byte, 32+2+paddingLen)
+		copy(authBuf[:32], account.PasswordSha256)
+		binary.BigEndian.PutUint16(authBuf[32:34], uint16(paddingLen))
+		// padding bytes are already zero
+
+		if _, err := conn.Write(authBuf); err != nil {
+			conn.Close()
+			return nil, errors.New("anytls: failed to send auth header").Base(err)
+		}
+		return conn, nil
+	}
+
+	c.pool = anysession.NewClient(
+		ctx,
+		dialOut,
+		anysession.DefaultPaddingForClient(),
+		30*time.Second, // idleSessionCheckInterval
+		60*time.Second, // idleSessionTimeout
+		1,              // minIdleSession
+	)
+	return c.pool
+}
