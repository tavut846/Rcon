index 00000000..a0568cbc
--- /dev/null
+++ b/infra/conf/anytls.go
@@ -0,0 +1,78 @@
+package conf
+
+import (
+	"github.com/xtls/xray-core/common/protocol"
+	"github.com/xtls/xray-core/common/serial"
+	"github.com/xtls/xray-core/common/task"
+	"github.com/xtls/xray-core/proxy/anytls"
+	"google.golang.org/protobuf/proto"
+)
+
+// AnyTLSUserConfig is the JSON representation of a single user for anytls inbound.
+type AnyTLSUserConfig struct {
+	Password string `json:"password"`
+	Level    uint32 `json:"level"`
+	Email    string `json:"email"`
+}
+
+// AnyTLSServerConfig is the JSON representation of an anytls inbound.
+type AnyTLSServerConfig struct {
+	Users         []*AnyTLSUserConfig `json:"users"`
+	Clients       []*AnyTLSUserConfig `json:"clients"` // alias for users
+	PaddingScheme string              `json:"paddingScheme"`
+}
+
+func (c *AnyTLSServerConfig) Build() (proto.Message, error) {
+	config := new(anytls.ServerConfig)
+	config.PaddingScheme = c.PaddingScheme
+
+	// allow "clients" as an alias for "users"
+	users := c.Users
+	if len(c.Clients) > 0 {
+		users = c.Clients
+	}
+
+	if len(users) > 0 {
+		config.Users = make([]*protocol.User, len(users))
+		buildUser := func(idx int) error {
+			u := users[idx]
+			acc := &anytls.Account{Password: u.Password}
+			config.Users[idx] = &protocol.User{
+				Email:   u.Email,
+				Level:   u.Level,
+				Account: serial.ToTypedMessage(acc),
+			}
+			return nil
+		}
+		if err := task.ParallelForN(len(users), buildUser); err != nil {
+			return nil, err
+		}
+	}
+
+	return config, nil
+}
+
+// AnyTLSClientConfig is the JSON representation of an anytls outbound.
+type AnyTLSClientConfig struct {
+	Address  *Address `json:"address"`
+	Port     uint16   `json:"port"`
+	Password string   `json:"password"`
+	Level    uint32   `json:"level"`
+	Email    string   `json:"email"`
+}
+
+func (c *AnyTLSClientConfig) Build() (proto.Message, error) {
+	acc := &anytls.Account{Password: c.Password}
+	config := &anytls.ClientConfig{
+		Server: &protocol.ServerEndpoint{
+			Address: c.Address.Build(),
+			Port:    uint32(c.Port),
+			User: &protocol.User{
+				Email:   c.Email,
+				Level:   c.Level,
+				Account: serial.ToTypedMessage(acc),
+			},
+		},
+	}
+	return config, nil
+}
