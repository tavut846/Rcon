diff --git a/proxy/anytls/server.go b/proxy/anytls/server.go
new file mode 100644
index 00000000..fd7f265b
--- /dev/null
+++ b/proxy/anytls/server.go
@@ -0,0 +1,219 @@
+package anytls
+
+import (
+	"context"
+	"encoding/binary"
+	"io"
+	"strings"
+	"time"
+
+	M "github.com/sagernet/sing/common/metadata"
+	"github.com/xtls/xray-core/common"
+	"github.com/xtls/xray-core/common/buf"
+	"github.com/xtls/xray-core/common/errors"
+	"github.com/xtls/xray-core/common/log"
+	"github.com/xtls/xray-core/common/net"
+	"github.com/xtls/xray-core/common/protocol"
+	"github.com/xtls/xray-core/common/session"
+	"github.com/xtls/xray-core/common/signal"
+	"github.com/xtls/xray-core/common/singbridge"
+	"github.com/xtls/xray-core/common/task"
+	"github.com/xtls/xray-core/core"
+	"github.com/xtls/xray-core/features/policy"
+	"github.com/xtls/xray-core/features/routing"
+	anysession "github.com/xtls/xray-core/proxy/anytls/session"
+	"github.com/xtls/xray-core/transport/internet/stat"
+)
+
+func init() {
+	common.Must(common.RegisterConfig((*ServerConfig)(nil), func(ctx context.Context, config interface{}) (interface{}, error) {
+		return NewServer(ctx, config.(*ServerConfig))
+	}))
+}
+
+// Server is an inbound handler for the AnyTLS protocol.
+type Server struct {
+	policyManager policy.Manager
+	validator     *Validator
+}
+
+func NewServer(ctx context.Context, config *ServerConfig) (*Server, error) {
+	v := core.MustFromContext(ctx)
+	s := &Server{
+		policyManager: v.GetFeature(policy.ManagerType()).(policy.Manager),
+		validator:     NewValidator(),
+	}
+
+	if config.PaddingScheme != "" {
+		if !anysession.UpdatePaddingScheme([]byte(config.PaddingScheme)) {
+			return nil, errors.New("invalid padding_scheme in server config")
+		}
+	}
+
+	for _, u := range config.Users {
+		mu, err := u.ToMemoryUser()
+		if err != nil {
+			return nil, errors.New("failed to parse anytls user").Base(err)
+		}
+		if err := s.validator.Add(mu); err != nil {
+			return nil, errors.New("failed to add anytls user").Base(err)
+		}
+	}
+
+	return s, nil
+}
+
+func (s *Server) AddUser(ctx context.Context, u *protocol.MemoryUser) error {
+	return s.validator.Add(u)
+}
+
+func (s *Server) RemoveUser(ctx context.Context, email string) error {
+	return s.validator.Del(email)
+}
+
+func (s *Server) GetUser(ctx context.Context, email string) *protocol.MemoryUser {
+	return s.validator.GetByEmail(email)
+}
+
+func (s *Server) GetUsers(ctx context.Context) []*protocol.MemoryUser {
+	return s.validator.GetAll()
+}
+
+func (s *Server) GetUsersCount(ctx context.Context) int64 {
+	return s.validator.GetCount()
+}
+
+func (s *Server) Network() []net.Network {
+	return []net.Network{net.Network_TCP, net.Network_UNIX}
+}
+
+// Process implements proxy.Inbound. TLS is handled by xray's transport layer.
+func (s *Server) Process(ctx context.Context, network net.Network, conn stat.Connection, dispatcher routing.Dispatcher) error {
+	sessionPolicy := s.policyManager.ForLevel(0)
+	if err := conn.SetReadDeadline(time.Now().Add(sessionPolicy.Timeouts.Handshake)); err != nil {
+		return errors.New("unable to set read deadline").Base(err).AtWarning()
+	}
+
+	// Authentication: sha256(password)[32] + padding_len[2] + padding[n]
+	var passwordBuf [32]byte
+	if _, err := io.ReadFull(conn, passwordBuf[:]); err != nil {
+		return errors.New("failed to read auth header").Base(err)
+	}
+
+	user := s.validator.Get(passwordBuf[:])
+	if user == nil {
+		log.Record(&log.AccessMessage{
+			From:   conn.RemoteAddr(),
+			To:     "",
+			Status: log.AccessRejected,
+			Reason: errors.New("invalid password"),
+		})
+		return errors.New("anytls: invalid auth from " + conn.RemoteAddr().String())
+	}
+
+	var lenBuf [2]byte
+	if _, err := io.ReadFull(conn, lenBuf[:]); err != nil {
+		return errors.New("failed to read padding length").Base(err)
+	}
+	if paddingLen := binary.BigEndian.Uint16(lenBuf[:]); paddingLen > 0 {
+		if _, err := io.ReadFull(conn, make([]byte, paddingLen)); err != nil {
+			return errors.New("failed to discard auth padding").Base(err)
+		}
+	}
+
+	if err := conn.SetReadDeadline(time.Time{}); err != nil {
+		return errors.New("unable to clear read deadline").Base(err).AtWarning()
+	}
+
+	inbound := session.InboundFromContext(ctx)
+	inbound.Name = "anytls"
+	inbound.User = user
+	sessionPolicy = s.policyManager.ForLevel(user.Level)
+
+	sess := anysession.NewServerSession(conn, func(stream *anysession.Stream) {
+		defer stream.Close()
+		if err := s.handleStream(ctx, stream, dispatcher, sessionPolicy); err != nil {
+			if errors.Cause(err) != io.EOF {
+				errors.LogInfoInner(ctx, err, "anytls: stream ended")
+			}
+		}
+	}, anysession.DefaultPaddingForClient())
+	sess.Run()
+	return nil
+}
+
+func (s *Server) handleStream(
+	ctx context.Context,
+	stream *anysession.Stream,
+	dispatcher routing.Dispatcher,
+	sessionPolicy policy.Session,
+) error {
+	// Each stream begins with a SOCKS5 address (sing SocksaddrSerializer format).
+	dest, err := M.SocksaddrSerializer.ReadAddrPort(stream)
+	if err != nil {
+		stream.HandshakeFailure(err) //nolint:errcheck
+		return errors.New("failed to read destination address").Base(err)
+	}
+
+	var xrayDest net.Destination
+	if strings.Contains(dest.Fqdn, "udp-over-tcp.arpa") {
+		// UDP-over-TCP magic domain
+		xrayDest = net.Destination{
+			Network: net.Network_UDP,
+			Address: net.DomainAddress(dest.Fqdn),
+			Port:    net.Port(dest.Port),
+		}
+	} else {
+		xrayDest, err = singbridge.ToDestination(dest, net.Network_TCP)
+		if err != nil {
+			stream.HandshakeFailure(err) //nolint:errcheck
+			return err
+		}
+	}
+
+	inbound := session.InboundFromContext(ctx)
+	ctx = log.ContextWithAccessMessage(ctx, &log.AccessMessage{
+		From:   stream.RemoteAddr(),
+		To:     xrayDest,
+		Status: log.AccessAccepted,
+		Reason: "",
+		Email:  inbound.User.Email,
+	})
+	errors.LogInfo(ctx, "anytls: tunnelling to ", xrayDest)
+
+	ctx, cancel := context.WithCancel(ctx)
+	timer := signal.CancelAfterInactivity(ctx, cancel, sessionPolicy.Timeouts.ConnectionIdle)
+	ctx = policy.ContextWithBufferPolicy(ctx, sessionPolicy.Buffer)
+
+	link, err := dispatcher.Dispatch(ctx, xrayDest)
+	if err != nil {
+		stream.HandshakeFailure(err) //nolint:errcheck
+		return errors.New("failed to dispatch to ", xrayDest).Base(err)
+	}
+
+	stream.HandshakeSuccess() //nolint:errcheck
+
+	requestDone := func() error {
+		defer timer.SetTimeout(sessionPolicy.Timeouts.DownlinkOnly)
+		if err := buf.Copy(buf.NewReader(stream), link.Writer, buf.UpdateActivity(timer)); err != nil {
+			return errors.New("failed to forward request").Base(err)
+		}
+		return nil
+	}
+
+	responseDone := func() error {
+		defer timer.SetTimeout(sessionPolicy.Timeouts.UplinkOnly)
+		if err := buf.Copy(link.Reader, buf.NewWriter(stream), buf.UpdateActivity(timer)); err != nil {
+			return errors.New("failed to forward response").Base(err)
+		}
+		return nil
+	}
+
+	requestDonePost := task.OnSuccess(requestDone, task.Close(link.Writer))
+	if err := task.Run(ctx, requestDonePost, responseDone); err != nil {
+		common.Interrupt(link.Reader)  //nolint:errcheck
+		common.Interrupt(link.Writer)  //nolint:errcheck
+		return errors.New("anytls: stream closed").Base(err)
+	}
+	return nil
+}
diff --git a/proxy/anytls/session/client_pool.go b/proxy/anytls/session/client_pool.go
new file mode 100644
index 00000000..f8449732
--- /dev/null
+++ b/proxy/anytls/session/client_pool.go
@@ -0,0 +1,223 @@
+package session
+
+import (
+	"container/heap"
+	"context"
+	"fmt"
+	"io"
+	"net"
+	"sync"
+	"sync/atomic"
+	"time"
+
+	"github.com/xtls/xray-core/common/errors"
+)
+
+// sessionHeap is a max-heap of Sessions ordered by descending seq (highest-seq first).
+type sessionHeap []*Session
+
+func (h sessionHeap) Len() int           { return len(h) }
+func (h sessionHeap) Less(i, j int) bool { return h[i].seq > h[j].seq }
+func (h sessionHeap) Swap(i, j int)      { h[i], h[j] = h[j], h[i] }
+func (h *sessionHeap) Push(x any)        { *h = append(*h, x.(*Session)) }
+func (h *sessionHeap) Pop() any {
+	old := *h
+	n := len(old)
+	x := old[n-1]
+	*h = old[:n-1]
+	return x
+}
+
+// Client manages a pool of AnyTLS sessions and multiplexes streams over them.
+type Client struct {
+	die       context.Context
+	dieCancel context.CancelFunc
+
+	dialOut func(ctx context.Context) (net.Conn, error)
+
+	sessionCounter atomic.Uint64
+
+	idleSession     sessionHeap
+	idleSessionLock sync.Mutex
+
+	sessions     map[uint64]*Session
+	sessionsLock sync.Mutex
+
+	padding *atomicPaddingFactory
+
+	idleSessionTimeout time.Duration
+	minIdleSession     int
+}
+
+func NewClient(
+	ctx context.Context,
+	dialOut func(ctx context.Context) (net.Conn, error),
+	padding *atomicPaddingFactory,
+	idleSessionCheckInterval, idleSessionTimeout time.Duration,
+	minIdleSession int,
+) *Client {
+	c := &Client{
+		sessions:           make(map[uint64]*Session),
+		dialOut:            dialOut,
+		padding:            padding,
+		idleSessionTimeout: idleSessionTimeout,
+		minIdleSession:     minIdleSession,
+	}
+	if idleSessionCheckInterval <= 5*time.Second {
+		idleSessionCheckInterval = 30 * time.Second
+	}
+	if c.idleSessionTimeout <= 5*time.Second {
+		c.idleSessionTimeout = 30 * time.Second
+	}
+	heap.Init(&c.idleSession)
+	c.die, c.dieCancel = context.WithCancel(ctx)
+	go c.idleCleanupLoop(idleSessionCheckInterval)
+	return c
+}
+
+// CreateStream returns a net.Conn that tunnels through an AnyTLS session.
+// It writes the SOCKS destination address on the stream before returning.
+func (c *Client) CreateStream(ctx context.Context) (net.Conn, error) {
+	select {
+	case <-c.die.Done():
+		return nil, io.ErrClosedPipe
+	default:
+	}
+
+	session := c.popIdleSession()
+	if session == nil {
+		var err error
+		session, err = c.createSession(ctx)
+		if session == nil {
+			return nil, fmt.Errorf("anytls: failed to create session: %w", err)
+		}
+	}
+
+	stream, err := session.OpenStream()
+	if err != nil {
+		session.Close()
+		return nil, fmt.Errorf("anytls: failed to open stream: %w", err)
+	}
+
+	stream.dieHook = func() {
+		if !session.IsClosed() {
+			select {
+			case <-c.die.Done():
+				go session.Close()
+			default:
+				c.idleSessionLock.Lock()
+				session.idleSince = time.Now()
+				heap.Push(&c.idleSession, session)
+				c.idleSessionLock.Unlock()
+			}
+		}
+	}
+
+	return stream, nil
+}
+
+func (c *Client) popIdleSession() *Session {
+	c.idleSessionLock.Lock()
+	defer c.idleSessionLock.Unlock()
+	if len(c.idleSession) == 0 {
+		return nil
+	}
+	return heap.Pop(&c.idleSession).(*Session)
+}
+
+func (c *Client) createSession(ctx context.Context) (*Session, error) {
+	conn, err := c.dialOut(ctx)
+	if err != nil {
+		return nil, err
+	}
+
+	session := NewClientSession(conn, c.padding)
+	seq := c.sessionCounter.Add(1)
+	session.seq = seq
+
+	session.dieHook = func() {
+		c.idleSessionLock.Lock()
+		for i, s := range c.idleSession {
+			if s.seq == seq {
+				heap.Remove(&c.idleSession, i)
+				break
+			}
+		}
+		c.idleSessionLock.Unlock()
+
+		c.sessionsLock.Lock()
+		delete(c.sessions, seq)
+		c.sessionsLock.Unlock()
+	}
+
+	c.sessionsLock.Lock()
+	c.sessions[seq] = session
+	c.sessionsLock.Unlock()
+
+	session.Run()
+	return session, nil
+}
+
+func (c *Client) Close() error {
+	c.dieCancel()
+
+	c.sessionsLock.Lock()
+	toClose := make([]*Session, 0, len(c.sessions))
+	for _, s := range c.sessions {
+		toClose = append(toClose, s)
+	}
+	c.sessions = make(map[uint64]*Session)
+	c.sessionsLock.Unlock()
+
+	for _, s := range toClose {
+		s.Close()
+	}
+	return nil
+}
+
+func (c *Client) idleCleanupLoop(interval time.Duration) {
+	ticker := time.NewTicker(interval)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-c.die.Done():
+			return
+		case <-ticker.C:
+			c.idleCleanup()
+		}
+	}
+}
+
+func (c *Client) idleCleanup() {
+	expTime := time.Now().Add(-c.idleSessionTimeout)
+
+	c.idleSessionLock.Lock()
+	var keep, remove []*Session
+	active := 0
+	for _, s := range c.idleSession {
+		if active < c.minIdleSession {
+			s.idleSince = time.Now()
+			keep = append(keep, s)
+			active++
+		} else if s.idleSince.Before(expTime) {
+			remove = append(remove, s)
+		} else {
+			keep = append(keep, s)
+			active++
+		}
+	}
+	c.idleSession = keep
+	heap.Init(&c.idleSession)
+	c.idleSessionLock.Unlock()
+
+	for _, s := range remove {
+		errors.LogDebug(context.Background(), "anytls: closing idle session ", s.seq)
+		s.Close()
+	}
+}
+
+// DefaultPaddingForClient returns the package-level default padding factory
+// wrapped in a pointer suitable for Client/Session use.
+func DefaultPaddingForClient() *atomicPaddingFactory {
+	return &DefaultPaddingFactory
+}
diff --git a/proxy/anytls/session/frame.go b/proxy/anytls/session/frame.go
new file mode 100644
index 00000000..b9fb6e18
--- /dev/null
+++ b/proxy/anytls/session/frame.go
@@ -0,0 +1,44 @@
+package session
+
+import "encoding/binary"
+
+const (
+	cmdWaste               byte = 0
+	cmdSYN                 byte = 1
+	cmdPSH                 byte = 2
+	cmdFIN                 byte = 3
+	cmdSettings            byte = 4
+	cmdAlert               byte = 5
+	cmdUpdatePaddingScheme byte = 6
+	// protocol version 2
+	cmdSYNACK         byte = 7
+	cmdHeartRequest   byte = 8
+	cmdHeartResponse  byte = 9
+	cmdServerSettings byte = 10
+)
+
+const headerOverHeadSize = 1 + 4 + 2 // cmd + streamId + length
+
+type frame struct {
+	cmd  byte
+	sid  uint32
+	data []byte
+}
+
+func newFrame(cmd byte, sid uint32) frame {
+	return frame{cmd: cmd, sid: sid}
+}
+
+type rawHeader [headerOverHeadSize]byte
+
+func (h rawHeader) Cmd() byte {
+	return h[0]
+}
+
+func (h rawHeader) StreamID() uint32 {
+	return binary.BigEndian.Uint32(h[1:])
+}
+
+func (h rawHeader) Length() uint16 {
+	return binary.BigEndian.Uint16(h[5:])
+}
diff --git a/proxy/anytls/session/padding.go b/proxy/anytls/session/padding.go
new file mode 100644
index 00000000..d86cc576
--- /dev/null
+++ b/proxy/anytls/session/padding.go
@@ -0,0 +1,120 @@
+package session
+
+import (
+	"crypto/md5"
+	"crypto/rand"
+	"fmt"
+	"math/big"
+	"strconv"
+	"strings"
+	"sync/atomic"
+	"unsafe"
+)
+
+const CheckMark = -1
+
+var defaultPaddingScheme = []byte(`stop=8
+0=30-30
+1=100-400
+2=400-500,c,500-1000,c,500-1000,c,500-1000,c,500-1000
+3=9-9,500-1000
+4=500-1000
+5=500-1000
+6=500-1000
+7=500-1000`)
+
+type PaddingFactory struct {
+	scheme    map[string]string
+	RawScheme []byte
+	Stop      uint32
+	Md5       string
+}
+
+// atomicPaddingFactory holds a *PaddingFactory via atomic pointer.
+type atomicPaddingFactory struct {
+	p unsafe.Pointer
+}
+
+func (a *atomicPaddingFactory) Load() *PaddingFactory {
+	return (*PaddingFactory)(atomic.LoadPointer(&a.p))
+}
+
+func (a *atomicPaddingFactory) Store(v *PaddingFactory) {
+	atomic.StorePointer(&a.p, unsafe.Pointer(v))
+}
+
+var DefaultPaddingFactory atomicPaddingFactory
+
+func init() {
+	UpdatePaddingScheme(defaultPaddingScheme)
+}
+
+func UpdatePaddingScheme(rawScheme []byte) bool {
+	if p := NewPaddingFactory(rawScheme); p != nil {
+		DefaultPaddingFactory.Store(p)
+		return true
+	}
+	return false
+}
+
+func NewPaddingFactory(rawScheme []byte) *PaddingFactory {
+	p := &PaddingFactory{
+		RawScheme: rawScheme,
+		Md5:       fmt.Sprintf("%x", md5.Sum(rawScheme)),
+	}
+	scheme := stringMapFromBytes(rawScheme)
+	if len(scheme) == 0 {
+		return nil
+	}
+	if stop, err := strconv.Atoi(scheme["stop"]); err == nil {
+		p.Stop = uint32(stop)
+	} else {
+		return nil
+	}
+	p.scheme = scheme
+	return p
+}
+
+func (p *PaddingFactory) GenerateRecordPayloadSizes(pkt uint32) (pktSizes []int) {
+	s, ok := p.scheme[strconv.Itoa(int(pkt))]
+	if !ok {
+		return
+	}
+	for _, sRange := range strings.Split(s, ",") {
+		parts := strings.Split(sRange, "-")
+		if len(parts) == 2 {
+			mn, err1 := strconv.ParseInt(parts[0], 10, 64)
+			mx, err2 := strconv.ParseInt(parts[1], 10, 64)
+			if err1 != nil || err2 != nil {
+				continue
+			}
+			if mn > mx {
+				mn, mx = mx, mn
+			}
+			if mn <= 0 || mx <= 0 {
+				continue
+			}
+			if mn == mx {
+				pktSizes = append(pktSizes, int(mn))
+			} else {
+				i, _ := rand.Int(rand.Reader, big.NewInt(mx-mn))
+				pktSizes = append(pktSizes, int(i.Int64()+mn))
+			}
+		} else if sRange == "c" {
+			pktSizes = append(pktSizes, CheckMark)
+		}
+	}
+	return
+}
+
+func stringMapFromBytes(b []byte) map[string]string {
+	m := make(map[string]string)
+	for _, line := range strings.Split(string(b), "\n") {
+		v := strings.SplitN(line, "=", 2)
+		if len(v) == 2 {
+			m[v[0]] = v[1]
+		}
+	}
+	return m
+}
+
diff --git a/proxy/anytls/session/pipe.go b/proxy/anytls/session/pipe.go
new file mode 100644
index 00000000..73a98c96
--- /dev/null
+++ b/proxy/anytls/session/pipe.go
@@ -0,0 +1,251 @@
+package session
+
+import (
+	"io"
+	"os"
+	"sync"
+	"time"
+)
+
+type onceError struct {
+	sync.Mutex
+	err error
+}
+
+func (a *onceError) Store(err error) {
+	a.Lock()
+	defer a.Unlock()
+	if a.err != nil {
+		return
+	}
+	a.err = err
+}
+
+func (a *onceError) Load() error {
+	a.Lock()
+	defer a.Unlock()
+	return a.err
+}
+
+type pipe struct {
+	wrMu sync.Mutex
+	wrCh chan []byte
+	rdCh chan int
+
+	once sync.Once
+	done chan struct{}
+	rerr onceError
+	werr onceError
+
+	readDeadline pipeDeadline
+}
+
+func (p *pipe) read(b []byte) (n int, err error) {
+	select {
+	case <-p.done:
+		return 0, p.readCloseError()
+	case <-p.readDeadline.wait():
+		return 0, os.ErrDeadlineExceeded
+	default:
+	}
+	select {
+	case bw := <-p.wrCh:
+		nr := copy(b, bw)
+		p.rdCh <- nr
+		return nr, nil
+	case <-p.done:
+		return 0, p.readCloseError()
+	case <-p.readDeadline.wait():
+		return 0, os.ErrDeadlineExceeded
+	}
+}
+
+func (p *pipe) closeRead(err error) error {
+	if err == nil {
+		err = io.ErrClosedPipe
+	}
+	p.rerr.Store(err)
+	p.once.Do(func() { close(p.done) })
+	return nil
+}
+
+func (p *pipe) write(b []byte) (n int, err error) {
+	select {
+	case <-p.done:
+		return 0, p.writeCloseError()
+	default:
+		p.wrMu.Lock()
+		defer p.wrMu.Unlock()
+	}
+	for once := true; once || len(b) > 0; once = false {
+		select {
+		case p.wrCh <- b:
+			nw := <-p.rdCh
+			b = b[nw:]
+			n += nw
+		case <-p.done:
+			return n, p.writeCloseError()
+		}
+	}
+	return n, nil
+}
+
+func (p *pipe) closeWrite(err error) error {
+	if err == nil {
+		err = io.EOF
+	}
+	p.werr.Store(err)
+	p.once.Do(func() { close(p.done) })
+	return nil
+}
+
+func (p *pipe) readCloseError() error {
+	rerr := p.rerr.Load()
+	if werr := p.werr.Load(); rerr == nil && werr != nil {
+		return werr
+	}
+	return io.ErrClosedPipe
+}
+
+func (p *pipe) writeCloseError() error {
+	werr := p.werr.Load()
+	if rerr := p.rerr.Load(); werr == nil && rerr != nil {
+		return rerr
+	}
+	return io.ErrClosedPipe
+}
+
+type PipeReader struct{ pipe }
+
+func (r *PipeReader) Read(data []byte) (n int, err error) {
+	return r.pipe.read(data)
+}
+
+func (r *PipeReader) Close() error {
+	return r.pipe.closeRead(nil)
+}
+
+func (r *PipeReader) SetReadDeadline(t time.Time) error {
+	if isClosedChan(r.done) {
+		return io.ErrClosedPipe
+	}
+	r.readDeadline.set(t)
+	return nil
+}
+
+type PipeWriter struct{ r PipeReader }
+
+func (w *PipeWriter) Write(data []byte) (n int, err error) {
+	return w.r.pipe.write(data)
+}
+
+func (w *PipeWriter) Close() error {
+	return w.r.pipe.closeWrite(nil)
+}
+
+func newPipe() (*PipeReader, *PipeWriter) {
+	pw := &PipeWriter{r: PipeReader{pipe: pipe{
+		wrCh:         make(chan []byte),
+		rdCh:         make(chan int),
+		done:         make(chan struct{}),
+		readDeadline: makePipeDeadline(),
+	}}}
+	return &pw.r, pw
+}
+
+type pipeDeadline struct {
+	mu     sync.Mutex
+	timer  *time.Timer
+	cancel chan struct{}
+}
+
+func makePipeDeadline() pipeDeadline {
+	return pipeDeadline{cancel: make(chan struct{})}
+}
+
+func (d *pipeDeadline) set(t time.Time) {
+	d.mu.Lock()
+	defer d.mu.Unlock()
+	if d.timer != nil && !d.timer.Stop() {
+		<-d.cancel
+	}
+	d.timer = nil
+	closed := isClosedChan(d.cancel)
+	if t.IsZero() {
+		if closed {
+			d.cancel = make(chan struct{})
+		}
+		return
+	}
+	if dur := time.Until(t); dur > 0 {
+		if closed {
+			d.cancel = make(chan struct{})
+		}
+		d.timer = time.AfterFunc(dur, func() {
+			close(d.cancel)
+		})
+		return
+	}
+	if !closed {
+		close(d.cancel)
+	}
+}
+
+func (d *pipeDeadline) wait() chan struct{} {
+	d.mu.Lock()
+	defer d.mu.Unlock()
+	return d.cancel
+}
+
+type writeDeadline struct {
+	mu     sync.Mutex
+	timer  *time.Timer
+	cancel chan struct{}
+}
+
+func makeWriteDeadline() writeDeadline {
+	return writeDeadline{cancel: make(chan struct{})}
+}
+
+func (d *writeDeadline) set(t time.Time) {
+	d.mu.Lock()
+	defer d.mu.Unlock()
+	if d.timer != nil && !d.timer.Stop() {
+		<-d.cancel
+	}
+	d.timer = nil
+	closed := isClosedChan(d.cancel)
+	if t.IsZero() {
+		if closed {
+			d.cancel = make(chan struct{})
+		}
+		return
+	}
+	if dur := time.Until(t); dur > 0 {
+		if closed {
+			d.cancel = make(chan struct{})
+		}
+		d.timer = time.AfterFunc(dur, func() {
+			close(d.cancel)
+		})
+		return
+	}
+	if !closed {
+		close(d.cancel)
+	}
+}
+
+func (d *writeDeadline) wait() chan struct{} {
+	d.mu.Lock()
+	defer d.mu.Unlock()
+	return d.cancel
+}
+
+func isClosedChan(c <-chan struct{}) bool {
+	select {
+	case <-c:
+		return true
+	default:
+		return false
+	}
+}
diff --git a/proxy/anytls/session/session.go b/proxy/anytls/session/session.go
new file mode 100644
index 00000000..9f16bf0c
--- /dev/null
+++ b/proxy/anytls/session/session.go
@@ -0,0 +1,516 @@
+package session
+
+import (
+	"context"
+	"crypto/md5"
+	"encoding/binary"
+	"fmt"
+	"io"
+	"net"
+	"runtime/debug"
+	"slices"
+	"strconv"
+	"strings"
+	"sync"
+	"sync/atomic"
+	"time"
+
+	"github.com/xtls/xray-core/common/errors"
+)
+
+const programVersionName = "xray-anytls/0.0.1"
+
+// atomicUint32 is a simple atomic uint32 wrapper.
+type atomicUint32 struct{ v uint32 }
+
+func (a *atomicUint32) Add(delta uint32) uint32 { return atomic.AddUint32(&a.v, delta) }
+func (a *atomicUint32) Load() uint32            { return atomic.LoadUint32(&a.v) }
+
+type Session struct {
+	conn     net.Conn
+	connLock sync.Mutex
+
+	streams    map[uint32]*Stream
+	streamId   atomicUint32
+	streamLock sync.RWMutex
+
+	dieOnce sync.Once
+	die     chan struct{}
+	dieHook func()
+
+	synDone     func()
+	synDoneLock sync.Mutex
+
+	// pool fields
+	seq       uint64
+	idleSince time.Time
+	padding   *atomicPaddingFactory
+
+	peerVersion byte
+
+	// client-only fields
+	isClient    bool
+	sendPadding bool
+	buffering   bool
+	buffer      []byte
+	pktCounter  atomicUint32
+
+	// server-only field
+	onNewStream func(stream *Stream)
+}
+
+func NewClientSession(conn net.Conn, padding *atomicPaddingFactory) *Session {
+	s := &Session{
+		conn:        conn,
+		isClient:    true,
+		sendPadding: true,
+		padding:     padding,
+	}
+	s.die = make(chan struct{})
+	s.streams = make(map[uint32]*Stream)
+	return s
+}
+
+func NewServerSession(conn net.Conn, onNewStream func(stream *Stream), padding *atomicPaddingFactory) *Session {
+	s := &Session{
+		conn:        conn,
+		onNewStream: onNewStream,
+		padding:     padding,
+	}
+	s.die = make(chan struct{})
+	s.streams = make(map[uint32]*Stream)
+	return s
+}
+
+func (s *Session) IsClosed() bool {
+	select {
+	case <-s.die:
+		return true
+	default:
+		return false
+	}
+}
+
+func (s *Session) Close() error {
+	var once bool
+	s.dieOnce.Do(func() {
+		close(s.die)
+		once = true
+	})
+	if once {
+		if s.dieHook != nil {
+			s.dieHook()
+			s.dieHook = nil
+		}
+		s.streamLock.Lock()
+		for _, stream := range s.streams {
+			stream.closeLocally()
+		}
+		s.streams = make(map[uint32]*Stream)
+		s.streamLock.Unlock()
+		return s.conn.Close()
+	}
+	return io.ErrClosedPipe
+}
+
+// Run starts the session. For the client it sends initial settings and starts the recv loop.
+func (s *Session) Run() {
+	if !s.isClient {
+		s.recvLoop()
+		return
+	}
+
+	settings := map[string]string{
+		"v":           "2",
+		"client":      programVersionName,
+		"padding-md5": s.padding.Load().Md5,
+	}
+	f := newFrame(cmdSettings, 0)
+	f.data = []byte(mapToSettingsStr(settings))
+	s.buffering = true
+	s.writeControlFrame(f) //nolint:errcheck
+	go s.recvLoop()
+}
+
+// OpenStream opens a new stream on this Session (client side).
+func (s *Session) OpenStream() (*Stream, error) {
+	if s.IsClosed() {
+		return nil, io.ErrClosedPipe
+	}
+
+	sid := s.streamId.Add(1)
+	stream := newStream(sid, s)
+
+	if sid >= 2 && s.peerVersion >= 2 {
+		s.synDoneLock.Lock()
+		if s.synDone != nil {
+			s.synDone()
+		}
+		s.synDone = newDeadlineWatcher(3*time.Second, func() { s.Close() })
+		s.synDoneLock.Unlock()
+	}
+
+	if _, err := s.writeControlFrame(newFrame(cmdSYN, sid)); err != nil {
+		return nil, err
+	}
+
+	s.buffering = false
+
+	s.streamLock.Lock()
+	defer s.streamLock.Unlock()
+	select {
+	case <-s.die:
+		return nil, io.ErrClosedPipe
+	default:
+		s.streams[sid] = stream
+		return stream, nil
+	}
+}
+
+func (s *Session) recvLoop() error {
+	defer func() {
+		if r := recover(); r != nil {
+			errors.LogError(context.Background(), fmt.Sprintf("[anytls BUG] %v\n%s", r, string(debug.Stack())))
+		}
+	}()
+	defer s.Close()
+
+	var receivedSettingsFromClient bool
+	var hdr rawHeader
+
+	for {
+		if s.IsClosed() {
+			return io.ErrClosedPipe
+		}
+
+		if _, err := io.ReadFull(s.conn, hdr[:]); err != nil {
+			return err
+		}
+
+		sid := hdr.StreamID()
+		switch hdr.Cmd() {
+
+		case cmdPSH:
+			if hdr.Length() > 0 {
+				buf := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, buf); err != nil {
+					return err
+				}
+				s.streamLock.RLock()
+				stream, ok := s.streams[sid]
+				s.streamLock.RUnlock()
+				if ok {
+					stream.pipeW.Write(buf) //nolint:errcheck
+				}
+			}
+
+		case cmdSYN:
+			if !s.isClient && !receivedSettingsFromClient {
+				f := newFrame(cmdAlert, 0)
+				f.data = []byte("client did not send its settings")
+				s.writeControlFrame(f) //nolint:errcheck
+				return nil
+			}
+			s.streamLock.Lock()
+			if _, ok := s.streams[sid]; !ok {
+				stream := newStream(sid, s)
+				s.streams[sid] = stream
+				go func() {
+					if s.onNewStream != nil {
+						s.onNewStream(stream)
+					} else {
+						stream.Close()
+					}
+				}()
+			}
+			s.streamLock.Unlock()
+
+		case cmdSYNACK:
+			s.synDoneLock.Lock()
+			if s.synDone != nil {
+				s.synDone()
+				s.synDone = nil
+			}
+			s.synDoneLock.Unlock()
+			if hdr.Length() > 0 {
+				buf := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, buf); err != nil {
+					return err
+				}
+				s.streamLock.RLock()
+				stream, ok := s.streams[sid]
+				s.streamLock.RUnlock()
+				if ok {
+					stream.closeWithError(fmt.Errorf("remote: %s", string(buf)))
+				}
+			}
+
+		case cmdFIN:
+			s.streamLock.Lock()
+			stream, ok := s.streams[sid]
+			delete(s.streams, sid)
+			s.streamLock.Unlock()
+			if ok {
+				stream.closeLocally()
+			}
+
+		case cmdWaste:
+			if hdr.Length() > 0 {
+				buf := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, buf); err != nil {
+					return err
+				}
+			}
+
+		case cmdSettings:
+			if hdr.Length() > 0 {
+				buf := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, buf); err != nil {
+					return err
+				}
+				if !s.isClient {
+					receivedSettingsFromClient = true
+					m := settingsStrToMap(string(buf))
+					paddingF := s.padding.Load()
+					if m["padding-md5"] != paddingF.Md5 {
+						f := newFrame(cmdUpdatePaddingScheme, 0)
+						f.data = paddingF.RawScheme
+						if _, err := s.writeControlFrame(f); err != nil {
+							return err
+						}
+					}
+					if v, err := strconv.Atoi(m["v"]); err == nil && v >= 2 {
+						s.peerVersion = byte(v)
+						f := newFrame(cmdServerSettings, 0)
+						f.data = []byte("v=2")
+						if _, err := s.writeControlFrame(f); err != nil {
+							return err
+						}
+					}
+				}
+			}
+
+		case cmdAlert:
+			if hdr.Length() > 0 {
+				buf := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, buf); err != nil {
+					return err
+				}
+				if s.isClient {
+					errors.LogWarning(context.Background(), "[anytls Alert from server] "+string(buf))
+				}
+			}
+			return nil
+
+		case cmdUpdatePaddingScheme:
+			if hdr.Length() > 0 {
+				rawScheme := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, rawScheme); err != nil {
+					return err
+				}
+				if s.isClient {
+					if UpdatePaddingScheme(rawScheme) {
+						errors.LogInfo(context.Background(), fmt.Sprintf("[anytls] Update padding succeed: %x", md5.Sum(rawScheme)))
+					} else {
+						errors.LogWarning(context.Background(), fmt.Sprintf("[anytls] Update padding failed: %x", md5.Sum(rawScheme)))
+					}
+				}
+			}
+
+		case cmdHeartRequest:
+			if _, err := s.writeControlFrame(newFrame(cmdHeartResponse, sid)); err != nil {
+				return err
+			}
+
+		case cmdHeartResponse:
+			// no-op
+
+		case cmdServerSettings:
+			if hdr.Length() > 0 {
+				buf := make([]byte, hdr.Length())
+				if _, err := io.ReadFull(s.conn, buf); err != nil {
+					return err
+				}
+				if s.isClient {
+					m := settingsStrToMap(string(buf))
+					if v, err := strconv.Atoi(m["v"]); err == nil {
+						s.peerVersion = byte(v)
+					}
+				}
+			}
+		}
+	}
+}
+
+func (s *Session) streamClosed(sid uint32) error {
+	if s.IsClosed() {
+		return io.ErrClosedPipe
+	}
+	_, err := s.writeControlFrame(newFrame(cmdFIN, sid))
+	s.streamLock.Lock()
+	delete(s.streams, sid)
+	s.streamLock.Unlock()
+	return err
+}
+
+func (s *Session) writeDataFrame(sid uint32, data []byte) (int, error) {
+	dataLen := len(data)
+	buf := make([]byte, headerOverHeadSize+dataLen)
+	buf[0] = cmdPSH
+	binary.BigEndian.PutUint32(buf[1:5], sid)
+	binary.BigEndian.PutUint16(buf[5:7], uint16(dataLen))
+	copy(buf[7:], data)
+	_, err := s.writeConn(buf)
+	if err != nil {
+		return 0, err
+	}
+	return dataLen, nil
+}
+
+func (s *Session) writeControlFrame(f frame) (int, error) {
+	dataLen := len(f.data)
+	buf := make([]byte, headerOverHeadSize+dataLen)
+	buf[0] = f.cmd
+	binary.BigEndian.PutUint32(buf[1:5], f.sid)
+	binary.BigEndian.PutUint16(buf[5:7], uint16(dataLen))
+	copy(buf[7:], f.data)
+
+	s.conn.SetWriteDeadline(time.Now().Add(5 * time.Second))
+	_, err := s.writeConn(buf)
+	s.conn.SetWriteDeadline(time.Time{})
+
+	if err != nil {
+		s.Close()
+		return 0, err
+	}
+	return dataLen, nil
+}
+
+func (s *Session) writeConn(b []byte) (n int, err error) {
+	s.connLock.Lock()
+	defer s.connLock.Unlock()
+
+	if s.buffering {
+		s.buffer = slices.Concat(s.buffer, b)
+		return len(b), nil
+	} else if len(s.buffer) > 0 {
+		b = slices.Concat(s.buffer, b)
+		s.buffer = nil
+	}
+
+	if s.sendPadding {
+		pkt := s.pktCounter.Add(1)
+		paddingF := s.padding.Load()
+		if pkt < paddingF.Stop {
+			pktSizes := paddingF.GenerateRecordPayloadSizes(pkt)
+			for _, l := range pktSizes {
+				remainLen := len(b)
+				if l == CheckMark {
+					if remainLen == 0 {
+						break
+					}
+					continue
+				}
+				if remainLen > l {
+					if _, err = s.conn.Write(b[:l]); err != nil {
+						return 0, err
+					}
+					n += l
+					b = b[l:]
+				} else if remainLen > 0 {
+					paddingLen := l - remainLen - headerOverHeadSize
+					if paddingLen > 0 {
+						pad := make([]byte, headerOverHeadSize+paddingLen)
+						pad[0] = cmdWaste
+						binary.BigEndian.PutUint32(pad[1:5], 0)
+						binary.BigEndian.PutUint16(pad[5:7], uint16(paddingLen))
+						b = slices.Concat(b, pad)
+					}
+					if _, err = s.conn.Write(b); err != nil {
+						return 0, err
+					}
+					n += remainLen
+					b = nil
+				} else {
+					pad := make([]byte, headerOverHeadSize+l)
+					pad[0] = cmdWaste
+					binary.BigEndian.PutUint16(pad[5:7], uint16(l))
+					if _, err = s.conn.Write(pad); err != nil {
+						return 0, err
+					}
+					b = nil
+				}
+			}
+			if len(b) == 0 {
+				return
+			}
+			n2, err := s.conn.Write(b)
+			return n + n2, err
+		}
+		s.sendPadding = false
+	}
+
+	return s.conn.Write(b)
+}
+
+func newDeadlineWatcher(d time.Duration, onTimeout func()) (cancel func()) {
+	t := time.NewTimer(d)
+	ch := make(chan struct{})
+	go func() {
+		defer t.Stop()
+		select {
+		case <-ch:
+		case <-t.C:
+			onTimeout()
+		}
+	}()
+	var once sync.Once
+	return func() { once.Do(func() { close(ch) }) }
+}
+
+func mapToSettingsStr(m map[string]string) string {
+	var b strings.Builder
+	first := true
+	for k, v := range m {
+		if !first {
+			b.WriteByte('\n')
+		}
+		b.WriteString(k)
+		b.WriteByte('=')
+		b.WriteString(v)
+		first = false
+	}
+	return b.String()
+}
+
+func settingsStrToMap(s string) map[string]string {
+	m := make(map[string]string)
+	for _, line := range splitLines(s) {
+		idx := -1
+		for i, c := range line {
+			if c == '=' {
+				idx = i
+				break
+			}
+		}
+		if idx >= 0 {
+			m[line[:idx]] = line[idx+1:]
+		}
+	}
+	return m
+}
+
+func splitLines(s string) []string {
+	var lines []string
+	start := 0
+	for i := 0; i < len(s); i++ {
+		if s[i] == '\n' {
+			lines = append(lines, s[start:i])
+			start = i + 1
+		}
+	}
+	if start < len(s) {
+		lines = append(lines, s[start:])
+	}
+	return lines
+}
diff --git a/proxy/anytls/session/stream.go b/proxy/anytls/session/stream.go
new file mode 100644
index 00000000..5b32cbcf
--- /dev/null
+++ b/proxy/anytls/session/stream.go
@@ -0,0 +1,141 @@
+package session
+
+import (
+	"io"
+	"net"
+	"os"
+	"sync"
+	"time"
+)
+
+// Stream implements net.Conn over a Session multiplexed connection.
+type Stream struct {
+	id uint32
+
+	sess *Session
+
+	pipeR         *PipeReader
+	pipeW         *PipeWriter
+	writeDeadline writeDeadline
+
+	dieOnce sync.Once
+	dieHook func()
+	dieErr  error
+
+	reportOnce sync.Once
+}
+
+func newStream(id uint32, sess *Session) *Stream {
+	s := new(Stream)
+	s.id = id
+	s.sess = sess
+	s.pipeR, s.pipeW = newPipe()
+	s.writeDeadline = makeWriteDeadline()
+	return s
+}
+
+func (s *Stream) Read(b []byte) (n int, err error) {
+	n, err = s.pipeR.Read(b)
+	if n == 0 && s.dieErr != nil {
+		err = s.dieErr
+	}
+	return
+}
+
+func (s *Stream) Write(b []byte) (n int, err error) {
+	select {
+	case <-s.writeDeadline.wait():
+		return 0, os.ErrDeadlineExceeded
+	default:
