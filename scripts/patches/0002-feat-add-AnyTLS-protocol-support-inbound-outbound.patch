diff --git a/proxy/anytls/account.go b/proxy/anytls/account.go
new file mode 100644
index 00000000..fa14ec12
--- /dev/null
+++ b/proxy/anytls/account.go
@@ -0,0 +1,109 @@
+package anytls
+
+import (
+	"crypto/sha256"
+	"encoding/hex"
+	"sync"
+
+	"google.golang.org/protobuf/proto"
+
+	"github.com/xtls/xray-core/common/errors"
+	"github.com/xtls/xray-core/common/protocol"
+)
+
+// MemoryAccount holds the parsed Account ready for use at runtime.
+type MemoryAccount struct {
+	Password       string
+	PasswordSha256 []byte // raw 32-byte sha256(password)
+}
+
+func (a *Account) AsAccount() (protocol.Account, error) {
+	sum := sha256.Sum256([]byte(a.Password))
+	return &MemoryAccount{
+		Password:       a.Password,
+		PasswordSha256: sum[:],
+	}, nil
+}
+
+func (m *MemoryAccount) Equals(other protocol.Account) bool {
+	o, ok := other.(*MemoryAccount)
+	if !ok {
+		return false
+	}
+	return m.Password == o.Password
+}
+
+func (m *MemoryAccount) ToProto() proto.Message {
+	return &Account{Password: m.Password}
+}
+
+// Validator stores the set of valid users for the inbound server,
+// keyed by hex-encoded sha256(password).
+type Validator struct {
+	mu    sync.RWMutex
+	users map[string]*protocol.MemoryUser
+}
+
+func NewValidator() *Validator {
+	return &Validator{users: make(map[string]*protocol.MemoryUser)}
+}
+
+func (v *Validator) Add(u *protocol.MemoryUser) error {
+	acc, ok := u.Account.(*MemoryAccount)
+	if !ok {
+		return errors.New("user account is not an anytls.MemoryAccount")
+	}
+	key := hex.EncodeToString(acc.PasswordSha256)
+	v.mu.Lock()
+	v.users[key] = u
+	v.mu.Unlock()
+	return nil
+}
+
+func (v *Validator) Del(email string) error {
+	v.mu.Lock()
+	defer v.mu.Unlock()
+	for k, u := range v.users {
+		if u.Email == email {
+			delete(v.users, k)
+			return nil
+		}
+	}
+	return errors.New("user not found: " + email)
+}
+
+// Get looks up a user by the raw 32-byte sha256 of their password.
+func (v *Validator) Get(sha256Bytes []byte) *protocol.MemoryUser {
+	key := hex.EncodeToString(sha256Bytes)
+	v.mu.RLock()
+	u := v.users[key]
+	v.mu.RUnlock()
+	return u
+}
+
+func (v *Validator) GetByEmail(email string) *protocol.MemoryUser {
+	v.mu.RLock()
+	defer v.mu.RUnlock()
+	for _, u := range v.users {
+		if u.Email == email {
+			return u
+		}
+	}
+	return nil
+}
+
+func (v *Validator) GetAll() []*protocol.MemoryUser {
+	v.mu.RLock()
+	defer v.mu.RUnlock()
+	all := make([]*protocol.MemoryUser, 0, len(v.users))
+	for _, u := range v.users {
+		all = append(all, u)
+	}
+	return all
+}
+
+func (v *Validator) GetCount() int64 {
+	v.mu.RLock()
+	defer v.mu.RUnlock()
+	return int64(len(v.users))
+}
